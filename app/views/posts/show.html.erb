<% content_for :title, @post.title %>

<div class="min-h-screen">
  <!-- Header -->
  <header class="bg-gradient-to-r from-sky-100 to-blue-100 shadow-sm border-b border-blue-100">
    <div class="max-w-6xl mx-auto px-4 py-6">
      <div class="flex items-center justify-between">
        <div>
          <%= link_to posts_path, class: "text-sky-600 hover:text-sky-800 transition-colors text-sm inline-flex items-center" do %>
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
            Back
          <% end %>
        </div>
      </div>
    </div>
  </header>

  <div class="max-w-4xl mx-auto px-4 py-10">
    <article class="bg-white/80 backdrop-blur-sm rounded-xl shadow-sm border border-sky-100 p-8">
      <!-- Post Header -->
      <header class="mb-10 relative">
        <span class="absolute -top-12 -left-6 text-4xl float-animation" aria-hidden="true">🎈</span>
        <h1 class="text-4xl font-bold text-sky-800 mb-5"><%= @post.title %></h1>
        <div class="flex flex-wrap items-center text-sky-600 space-x-6 mb-6">
          <div class="flex items-center">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
            </svg>
            <span>By <%= @post.author %></span>
          </div>
          <div class="flex items-center">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
            </svg>
            <time><%= @post.created_at.strftime("%B %d, %Y") %></time>
          </div>

        </div>
      </header>

      <!-- Post Content -->
      <div class="prose prose-lg max-w-none text-blue-900/80 leading-relaxed">
        <%= simple_format(@post.content, {}, wrapper_tag: "div") %>
      </div>

      <!-- Post Footer -->
      <footer class="mt-12 pt-8 border-t border-sky-100">
        <div class="flex items-center justify-between">
            <div class="flex items-center space-x-4">
              <%= link_to edit_post_path(@post), class: "text-sky-500 hover:text-sky-700 text-sm inline-flex items-center" do %>
                <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg> Edit
              <% end %>
              <span class="text-sky-200">•</span>
              <%= link_to @post, method: :delete, data: { confirm: "Are you sure you want to delete this post?" }, class: "text-red-500 hover:text-red-700 text-sm inline-flex items-center" do %>
                <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg> Delete
              <% end %>
            </div>
        </div>
      </footer>
    </article>

    <!-- Comments Section -->
    <div class="mt-12">
      <div class="bg-white/70 backdrop-blur-sm rounded-xl shadow-sm border border-sky-100 p-8">
        <h2 class="text-2xl font-bold text-sky-800 mb-6 flex items-center">
          <svg class="w-6 h-6 mr-3 text-sky-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
          </svg>
          Comments (<%= @comments.count %>)
        </h2>

        <!-- Comment Form -->
        <div class="mb-8">
          <%= form_with model: [@post, @comment], local: true, class: "space-y-4 bg-blue-50/50 p-6 rounded-xl border border-sky-100" do |form| %>
            <div>
              <%= form.label :username, class: "block text-sm font-medium text-sky-700 mb-2" %>
              <%= form.text_field :username, class: "w-full px-5 py-3 border border-sky-200 rounded-full focus:ring-2 focus:ring-sky-400 focus:border-transparent bg-white shadow-sm", placeholder: "Your name" %>
            </div>
            <div>
              <%= form.label :content, class: "block text-sm font-medium text-sky-700 mb-2" %>
              <%= form.text_area :content, rows: 4, class: "w-full px-5 py-3 border border-sky-200 rounded-xl focus:ring-2 focus:ring-sky-400 focus:border-transparent bg-white shadow-sm", placeholder: "Let your thoughts float up..." %>
            </div>
            <div class="flex justify-end">
              <%= form.submit "Post Comment", class: "bg-gradient-to-r from-sky-500 to-blue-500 text-white px-6 py-2 rounded-full hover:from-sky-600 hover:to-blue-600 transition-colors shadow-sm" %>
            </div>
          <% end %>
        </div>

        <!-- Comments List -->
        <% if @comments.any? %>
          <div class="space-y-6">
            <% @comments.each do |comment| %>
              <div class="border-l-4 border-sky-200 pl-5 py-2 hover:bg-sky-50/50 rounded-r-lg transition-colors">
                <div class="flex items-start justify-between mb-3">
                  <div class="flex items-center space-x-3">
                    <div class="w-10 h-10 bg-gradient-to-r from-sky-500 to-blue-500 rounded-full flex items-center justify-center text-white text-sm font-semibold shadow-sm float-animation" style="animation-duration: 3s;">
                      <%= comment.username.first.upcase %>
                    </div>
                    <div>
                      <p class="font-medium text-sky-800"><%= comment.username %></p>
                      <p class="text-sm text-sky-500 flex items-center">
                        <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                        <%= comment.created_date %>
                      </p>
                    </div>
                  </div>
                </div>
                <div class="text-blue-900/80 pl-3">
                  <%= simple_format(comment.content) %>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-10 bg-sky-50/50 rounded-xl">
            <div class="inline-block p-5 bg-sky-100/80 rounded-full mb-5 float-animation" style="animation-duration: 5s;">
              <svg class="w-12 h-12 text-sky-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
              </svg>
            </div>
            <p class="text-sky-600">Be the first to share your thoughts!</p>
            <p class="text-sky-500 text-sm mt-2">Your comment will float to the top</p>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Recent Posts -->
    <% if @recent_posts.any? %>
      <div class="mt-12">
        <h2 class="text-2xl font-bold text-sky-800 mb-6 flex items-center">
          <svg class="w-6 h-6 mr-3 text-sky-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"></path>
          </svg>
          More Uplifting Posts
        </h2>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          <% @recent_posts.each do |post| %>
            <div class="bg-white/70 backdrop-blur-sm rounded-xl shadow-sm border border-sky-100 p-6 hover:shadow-md transition-all duration-300 transform hover:-translate-y-1 group">
              <h3 class="text-lg font-semibold text-sky-800 mb-3 group-hover:text-sky-600 transition-colors line-clamp-2">
                <%= link_to post.title, post %>
              </h3>
              <p class="text-sky-700/90 text-sm mb-4 line-clamp-3"><%= post.content %></p>
              <div class="flex items-center justify-between text-xs text-sky-500">
                <span class="flex items-center">
                  <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                  </svg>
                  <%= post.author %>
                </span>
                <time class="flex items-center">
                  <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                  </svg>
                  <%= post.created_at.strftime("%b %d") %>
                </time>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
