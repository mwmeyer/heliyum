<% content_for :title, "Heliyum Blog" %>

<div class="min-h-screen">
  <!-- Header -->
  <header class="bg-gradient-to-r from-sky-100 to-blue-100 shadow-sm border-b border-blue-100">
    <div class="max-w-6xl mx-auto px-4 py-8">
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-4xl font-bold text-sky-800 flex items-center">
            <span class="inline-block mr-3 float-animation">🎈</span>
            Heliyum
          </h1>
          <p class="text-sky-600 mt-2">a deliciously lightweight blog</p>
        </div>
        
        <%= link_to '/posts/new', class: "inline-flex items-center px-8 py-3 bg-gradient-to-r from-sky-400 to-blue-500 text-white rounded-full font-medium hover:from-sky-500 hover:to-blue-600 transition-colors shadow-md" do %>
          New Post
        <% end %>
      </div>
    </div>
  </header>

  <div class="max-w-6xl mx-auto px-4 py-10">
    <div class="grid lg:grid-cols-4 gap-10">
      <!-- Main Content -->
      <div class="lg:col-span-3">
        <!-- Search Bar -->
        <div class="mb-10">
          <%= form_with url: posts_path, method: :get, class: "flex gap-3" do |form| %>
            <%= form.text_field :search, value: @search_query, placeholder: "Float away with your search...", class: "flex-1 px-6 py-3 border border-sky-200 rounded-full focus:ring-2 focus:ring-sky-400 focus:border-transparent bg-white/80 backdrop-blur-sm shadow-sm" %>
            <%= form.submit "Search", class: "bg-gradient-to-r from-sky-500 to-blue-500 text-white px-6 py-3 rounded-full hover:from-sky-600 hover:to-blue-600 transition-colors shadow-sm" %>
          <% end %>
        </div>

        <!-- Posts List -->
        <% if @posts.any? %>
          <div class="space-y-8">
            <% @posts.each do |post| %>
              <article class="bg-white/70 backdrop-blur-sm rounded-xl shadow-sm border border-sky-100 p-8 hover:shadow-lg transition-all duration-300 transform hover:-translate-y-1 group">
                <div class="flex items-start justify-between mb-5">
                  <div class="flex-1">
                    <h2 class="text-2xl font-bold text-sky-800 mb-3 group-hover:text-sky-600 transition-colors">
                      <%= link_to post.title, post %>
                    </h2>
                    <div class="flex flex-wrap items-center text-sm text-sky-600 space-x-4">
                      <span class="flex items-center"><svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg> <%= post.author %></span>
                      <span>•</span>
                      <time class="flex items-center"><svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg> <%= post.created_at.strftime("%B %d, %Y") %></time>
                    </div>
                  </div>
                </div>


                <div class="flex items-center justify-between">
                  <div class="flex items-center space-x-4">
                    <%= link_to post, class: "inline-flex items-center px-5 py-2 bg-gradient-to-r from-sky-400 to-blue-500 text-white rounded-full font-medium text-sm hover:from-sky-500 hover:to-blue-600 transition-colors shadow-sm" do %>
                      Read More <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                    <% end %>
                    <span class="text-sky-500 text-sm flex items-center">
                      <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"></path></svg>
                      <%= pluralize(post.comments_count, 'comment') %>
                    </span>
                  </div>
                  <div class="flex items-center space-x-2">
                    <%= link_to edit_post_path(post), class: "text-sky-500 hover:text-sky-700 text-sm flex items-center" do %>
                      <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg> Edit
                    <% end %>
                    <span class="text-gray-300">•</span>
                    <%= link_to post, method: :delete, data: { confirm: "Are you sure?" }, class: "text-red-500 hover:text-red-700 text-sm flex items-center" do %>
                      <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg> Delete
                    <% end %>
                  </div>
                </div>
              </article>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-16 px-6 bg-white/50 backdrop-blur-sm rounded-2xl border border-sky-100 shadow-sm">
            <div class="inline-block p-6 bg-sky-50 rounded-full mb-6">
              <svg class="w-16 h-16 text-sky-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
              </svg>
            </div>
            <h3 class="text-2xl font-medium text-sky-800 mb-3">No posts yet</h3>
              <p class="text-sky-600 mb-8">Your blog is waiting for its first words to float up</p>
              <%= link_to '/posts/new', class: "inline-flex items-center px-8 py-3 bg-gradient-to-r from-sky-400 to-blue-500 text-white rounded-full font-medium hover:from-sky-500 hover:to-blue-600 transition-colors shadow-md" do %>
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path></svg> Write Your First Post
              <% end %>
          </div>
        <% end %>
      </div>

      <!-- Sidebar -->
      <div class="lg:col-span-1">
        <div class="space-y-8">
          <!-- Stats Card -->
          <div class="bg-white/70 backdrop-blur-sm rounded-xl shadow-sm border border-sky-100 p-6 transform transition-all duration-300 hover:shadow-md">
            <h3 class="text-xl font-semibold text-sky-800 mb-5 flex items-center">
              <svg class="w-5 h-5 mr-2 text-sky-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
              Blog Stats
            </h3>
            <div class="space-y-4">
              <div class="flex justify-between items-center bg-sky-50 p-3 rounded-lg">
                <span class="text-sky-700">Total Posts</span>
                <span class="font-semibold text-sky-800 text-lg"><%= @total_posts %></span>
              </div>
              <div class="flex justify-between items-center bg-amber-50 p-3 rounded-lg">
                <span class="text-amber-700">Comments</span>
                <span class="font-semibold text-amber-800 text-lg"><%= Comment.count rescue 0 %></span>
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>
  </div>
</div>
