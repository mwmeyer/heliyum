<% content_for :title, "Heliyum - a deliciously lightweight blog" %>

<div class="min-h-screen flex items-center justify-center px-4">
  <div class="max-w-4xl w-full">
    <!-- Header -->
    <div class="text-center mb-16">
      <div class="inline-flex items-center justify-center w-24 h-24 bg-gradient-to-r from-sky-500 to-blue-500 rounded-full mb-8 shadow-lg float-animation">
        <svg class="w-14 h-14 text-white" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 4C16.4183 4 20 7.58172 20 12C20 13.9569 19.3167 15.7496 18.1522 17.1324C17.8657 17.4725 17.6638 17.9224 17.605 18.4125L17.5 19.2L17.5067 19.2139C15.9119 20.3257 13.9928 21 12 21C10.7979 21 9.64292 20.7574 8.59687 20.3159C8.86475 20.1106 9 19.7922 9 19.2L9 13C9 12.4477 9.44771 12 10 12L18 12C18.4633 12 18.8475 12.2876 18.9619 12.6822C18.9871 12.4542 19 12.2289 19 12C19 8.13401 15.866 5 12 5C8.13401 5 5 8.13401 5 12C5 15.866 8.13401 19 12 19H13C13.5523 19 14 19.4477 14 20C14 20.5523 13.5523 21 13 21H12C7.58172 21 4 17.4183 4 12C4 6.58172 7.58172 4 12 4Z" fill="currentColor"/>
        </svg>
      </div>
      <h1 class="text-5xl font-bold text-sky-800 mb-6">Welcome to Heliyum Blog!</h1>
      <p class="text-xl text-sky-600 mb-4">a deliciously lightweight blog</p>
      <div class="inline-flex items-center px-5 py-2 bg-gradient-to-r from-sky-100 to-blue-100 text-sky-700 rounded-full text-sm font-medium shadow-sm">
        <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
        </svg>
        Ready to Float
      </div>
    </div>

    <!-- Main Content -->
    <div class="grid md:grid-cols-2 gap-10 mb-16">
      <!-- Heliyum Features -->
      <div class="bg-white/80 backdrop-blur-sm rounded-xl shadow-sm border border-sky-100 p-8 transform hover:shadow-md transition-all duration-300 hover:-translate-y-1">
        <h2 class="text-2xl font-bold text-sky-800 mb-6 flex items-center">
          <span class="inline-block mr-3 text-2xl float-animation">🎈</span>
          Heliyum Features
        </h2>
        <ul class="space-y-4">
          <li class="flex items-start text-sky-700">
            <svg class="w-5 h-5 text-sky-500 mr-3 mt-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
            </svg>
            <span>Lightweight design with<br>floating animations</span>
          </li>
          <li class="flex items-start text-sky-700">
            <svg class="w-5 h-5 text-sky-500 mr-3 mt-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
            </svg>
            <span>Simple username-based<br>commenting system</span>
          </li>
          <li class="flex items-start text-sky-700">
            <svg class="w-5 h-5 text-sky-500 mr-3 mt-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
            </svg>
            <span>Easy admin access with<br>HTTP Basic Authentication</span>
          </li>
          <li class="flex items-start text-sky-700">
            <svg class="w-5 h-5 text-sky-500 mr-3 mt-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
            </svg>
            <span>Clean, responsive design<br>with Tailwind CSS</span>
          </li>
        </ul>
      </div>

      <!-- Tech Details -->
      <div class="bg-white/80 backdrop-blur-sm rounded-xl shadow-sm border border-sky-100 p-8 transform hover:shadow-md transition-all duration-300 hover:-translate-y-1">
        <h2 class="text-2xl font-bold text-sky-800 mb-6 flex items-center">
          <svg class="w-6 h-6 mr-3 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"></path>
          </svg>
          Tech Stack
        </h2>
        <ul class="space-y-4">
          <li class="flex items-start text-sky-700">
            <svg class="w-5 h-5 text-sky-500 mr-3 mt-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
            </svg>
            <span>Rails 8 with SQLite<br>relational database</span>
          </li>
          <li class="flex items-start text-sky-700">
            <svg class="w-5 h-5 text-sky-500 mr-3 mt-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
            </svg>
            <span>Tailwind CSS for<br>beautiful responsive design</span>
          </li>
          <li class="flex items-start text-sky-700">
            <svg class="w-5 h-5 text-sky-500 mr-3 mt-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
            </svg>
            <span>Deployed on Fly.io with<br>global edge deployment</span>
          </li>
          <li class="flex items-start text-sky-700">
            <svg class="w-5 h-5 text-sky-500 mr-3 mt-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
            </svg>
            <span>Docker-containerized for<br>zero-downtime deployments</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Blog Demo -->
    <div class="bg-gradient-to-r from-sky-500 to-blue-500 rounded-xl shadow-lg p-10 text-white mb-12 relative overflow-hidden">
      <!-- Floating bubbles -->
      <div class="absolute top-4 right-10 w-20 h-20 rounded-full bg-white opacity-10 float-animation" style="animation-delay: 0.5s"></div>
      <div class="absolute bottom-10 left-10 w-16 h-16 rounded-full bg-white opacity-10 float-animation" style="animation-delay: 1.5s"></div>

      <h2 class="text-3xl font-bold mb-6 text-center flex items-center justify-center">
        <span class="inline-block mr-3 float-animation">🎈</span>
        Heliyum Blog
      </h2>
      <div class="max-w-3xl mx-auto">
        <p class="text-lg mb-8 text-center text-sky-100">
            A deliciously lightweight blogging platform that lets your ideas float freely.
          </p>

        <div class="text-center mb-10">
          <%= link_to posts_path, class: "inline-flex items-center px-8 py-4 bg-white text-sky-600 rounded-full font-bold text-lg hover:bg-sky-50 transition-colors shadow-lg transform hover:-translate-y-1 transition-transform duration-300" do %>
            <span class="mr-2">✨</span> Explore the Blog <span class="ml-2">→</span>
          <% end %>
        </div>

        <div class="text-center bg-white/10 backdrop-blur-sm rounded-xl p-6">
          <p class="text-sky-100 text-sm mb-4">Share your thoughts with just your name - no login required!</p>
          <div class="flex justify-center">
            <%= link_to posts_path, class: "bg-white text-sky-600 px-6 py-3 rounded-full hover:bg-sky-50 transition-colors shadow-sm" do %>
              Start Reading Now
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <!-- Admin Info -->
    <div class="bg-gradient-to-r from-indigo-500 to-blue-500 rounded-xl shadow-lg p-10 text-white relative overflow-hidden">
      <!-- Floating bubbles -->
      <div class="absolute top-10 left-10 w-20 h-20 rounded-full bg-white opacity-10 float-animation" style="animation-delay: 1s"></div>
      <div class="absolute bottom-6 right-10 w-16 h-16 rounded-full bg-white opacity-10 float-animation" style="animation-delay: 2s"></div>

      <h2 class="text-3xl font-bold mb-6 text-center">🔐 Admin Access</h2>
      <div class="max-w-3xl mx-auto">
        <p class="text-lg mb-6 text-center text-blue-100">
          This blog includes HTTP Basic Authentication for admin access to create, edit, and delete posts.
        </p>

        <div class="grid md:grid-cols-2 gap-6 bg-white/10 backdrop-blur-sm rounded-xl p-6 mb-6">
          <div class="text-center p-4">
            <h3 class="text-lg font-semibold mb-2">Default Credentials</h3>
            <p class="text-sm mb-1"><strong>Username:</strong> admin</p>
            <p class="text-sm"><strong>Password:</strong> password</p>
          </div>
          <div class="text-center p-4">
            <h3 class="text-lg font-semibold mb-2">Change with ENV Variables</h3>
            <p class="text-sm mb-1"><code>ADMIN_USERNAME</code></p>
            <p class="text-sm"><code>ADMIN_PASSWORD</code></p>
          </div>
        </div>

        <div class="text-center">
          <a href="https://fly.io/docs/rails/" target="_blank" class="inline-flex items-center px-6 py-3 bg-white text-indigo-600 rounded-full font-semibold hover:bg-indigo-50 transition-colors shadow-sm">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
            </svg>
            Deployment Guide
          </a>
        </div>
      </div>
    </div>

    <!-- Footer -->
    <div class="text-center mt-12 text-sky-500">
      <p class="flex items-center justify-center">
        Heliyum - a deliciously lightweight blog
      </p>
    </div>
  </div>
</div>
