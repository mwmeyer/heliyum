<% content_for :title, "Edit Post - #{@post.title}" %>

<div class="min-h-screen">
  <!-- Header -->
  <header class="bg-gradient-to-r from-sky-100 to-blue-100 shadow-sm border-b border-blue-100">
    <div class="max-w-4xl mx-auto px-4 py-8">
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-3xl font-bold text-sky-800 flex items-center">
            <span class="inline-block mr-3 float-animation">🎈</span>
            Edit Post
          </h1>
          <p class="text-sky-600 mt-2">Update your floating ideas</p>
        </div>
        <div class="flex items-center space-x-4">
          <%= link_to @post, class: "text-sky-600 hover:text-sky-800 transition-colors inline-flex items-center" do %>
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
            Back to Post
          <% end %>
        </div>
      </div>
    </div>
  </header>

  <div class="max-w-4xl mx-auto px-4 py-10">
    <div class="bg-white/80 backdrop-blur-sm rounded-xl shadow-sm border border-sky-100 p-8">
      <%= form_with model: @post, local: true, class: "space-y-6" do |form| %>
        <% if @post.errors.any? %>
          <div class="bg-red-50 border border-red-200 rounded-xl p-5">
            <h3 class="text-sm font-medium text-red-800 mb-2 flex items-center">
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
              Please fix the following errors:
            </h3>
            <ul class="text-sm text-red-700 space-y-1">
              <% @post.errors.full_messages.each do |message| %>
                <li>• <%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div>
          <%= form.label :title, class: "block text-sm font-medium text-sky-700 mb-2" %>
          <%= form.text_field :title, class: "w-full px-5 py-3 border border-sky-200 rounded-xl focus:ring-2 focus:ring-sky-400 focus:border-transparent text-xl shadow-sm", placeholder: "Enter an uplifting title..." %>
        </div>

        <div>
          <%= form.label :author, class: "block text-sm font-medium text-sky-700 mb-2" %>
          <%= form.text_field :author, class: "w-full px-5 py-3 border border-sky-200 rounded-xl focus:ring-2 focus:ring-sky-400 focus:border-transparent shadow-sm", placeholder: "Author name" %>
        </div>

        <div>
          <%= form.label :content, class: "block text-sm font-medium text-sky-700 mb-2" %>
          <%= form.text_area :content, rows: 15, class: "w-full px-5 py-3 border border-sky-200 rounded-xl focus:ring-2 focus:ring-sky-400 focus:border-transparent font-mono text-sm shadow-sm", placeholder: "Let your ideas float here..." %>
        </div>



        <div class="flex items-center justify-between pt-6 border-t border-sky-100">
          <div class="text-sm text-sky-500 flex items-center">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            <p>Edit your post - changes publish immediately</p>
          </div>
          <div class="flex items-center space-x-4">
            <%= link_to "Cancel", @post, class: "px-6 py-2 border border-sky-200 text-sky-700 rounded-full hover:bg-sky-50 transition-colors shadow-sm" %>
            <%= form.submit "Update Post", class: "bg-gradient-to-r from-sky-500 to-blue-500 text-white px-6 py-2 rounded-full hover:from-sky-600 hover:to-blue-600 transition-colors shadow-sm font-medium" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
